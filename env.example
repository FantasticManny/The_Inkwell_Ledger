# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
# Local example:   postgresql://postgres:yourpassword@localhost:5432/blogcms
# Neon example:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/blogcms?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/blogcms

# ─── Session ──────────────────────────────────────────────
# Generate a strong secret by running this in your terminal:
# node -e "require('crypto').randomBytes(64).toString('hex')"
SESSION_SECRET=replace_this_with_a_long_random_string

# ─── Google OAuth ─────────────────────────────────────────
# Setup: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Redirect URI to register: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── GitHub OAuth (optional) ──────────────────────────────
# Setup: github.com → Settings → Developer settings → OAuth Apps
# Callback URL to register: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ─── Cloudinary ───────────────────────────────────────────
# Setup: cloudinary.com → Dashboard (all three values are on the homepage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── App ──────────────────────────────────────────────────
APP_URL=http://localhost:3000

# The first person to sign in with this email is automatically made admin
ADMIN_EMAIL=your@email.com
